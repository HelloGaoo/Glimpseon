<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ClassLively_UI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassLively_UI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,20">
        <StackPanel Spacing="24">

            <!-- 页面标题 -->
            <TextBlock Text="关于" Style="{StaticResource TitleTextBlockStyle}" FontSize="28" Margin="0,0,0,8" />

            <!-- 应用信息卡片 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24,20">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <FontIcon Glyph="&#xE790;" FontSize="48" Width="64" Height="64"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="ClassLively" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="114514" Opacity="0.6" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <TextBlock x:Name="VersionTextBlock" Text="版本：--" Opacity="0.7" FontSize="12" />
                                <TextBlock x:Name="BuildDateTextBlock" Text="构建日期：--" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 详细信息区 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                    <FontIcon Glyph="&#xE946;" Grid.Row="0" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="版本号" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock x:Name="DetailVersionText" Text="--" Grid.Column="1" Grid.Row="1" Opacity="0.65" FontSize="13" />

                    <FontIcon Glyph="&#xE783;" Grid.Row="2" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="构建日期" Grid.Column="1" Grid.Row="2" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock x:Name="DetailBuildDateText" Text="--" Grid.Column="1" Grid.Row="3" Opacity="0.65" FontSize="13" />

                    <FontIcon Glyph="&#xE77B;" Grid.Row="4" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="作者" Grid.Column="1" Grid.Row="4" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="HelloGaoo" Grid.Column="1" Grid.Row="5" Opacity="0.65" FontSize="13" />

                    <Button Content="鸣谢" Click="CreditsButton_Click"
                            Grid.ColumnSpan="2" Grid.Row="6"
                            HorizontalAlignment="Right" Margin="0,8,0,0" />
                </Grid>
            </Border>

            <!-- 链接区域 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <StackPanel Spacing="16">

                    <!-- GitHub 仓库 -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Glyph="&#xE70F;" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#238636" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="GitHub 仓库" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="查看源代码" Opacity="0.55" FontSize="12" />
                        </StackPanel>
                        <Button Content="访问" Click="GitHubVisit_Click" Grid.Column="2"
                                VerticalAlignment="Center" />
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- 作者主页 -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Glyph="&#xE71D;" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#00A1D6" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="作者主页 (Bilibili)" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="访问作者的Bilibili" Opacity="0.55" FontSize="12" />
                        </StackPanel>
                        <Button Content="访问" Click="AuthorHomepage_Click" Grid.Column="2"
                                VerticalAlignment="Center" />
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- 开源许可 -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Glyph="&#xE72C;" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#FF9800" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="开源许可证" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="GNU General Public License v3.0" Opacity="0.55" FontSize="12" />
                        </StackPanel>
                        <Button Content="查看" Click="LicenseButton_Click" Grid.Column="2"
                                VerticalAlignment="Center" />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- 更新日志 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="更新日志" FontWeight="SemiBold" FontSize="15" />
                    </StackPanel>
                    <TextBox x:Name="ChangelogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="180"
                             Text="114514"
                             PlaceholderText="暂无更新日志" />
                </StackPanel>
            </Border>

            <!-- 页脚 -->
            <TextBlock Text="© 2026 HelloGaoo ClassLively · GNU General Public License v3.0"
                       HorizontalAlignment="Center"
                       Opacity="0.45" FontSize="11"
                       Margin="0,8,0,0" />

        </StackPanel>
    </ScrollViewer>
</Page>
