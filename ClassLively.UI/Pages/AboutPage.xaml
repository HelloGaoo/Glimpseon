<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClassLively_UI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="60,12,60,24">
        <StackPanel Spacing="10">

            <!-- 顶部卡片：图标 名称 版本 描述 -->
            <Border x:Name="HeaderCard"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="32,20,32,16">
                <StackPanel Spacing="6">
                    <!-- 72x72 图标 -->
                    <Image Width="72" Height="72"
                           Source="ms-appx:///Assets/CY.png"
                           HorizontalAlignment="Left"/>

                    <!-- 应用名称 -->
                    <TextBlock Text="ClassLively"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <!-- 描述文字 -->
                    <TextBlock x:Name="DescriptionText"
                               Text="114514"
                               Opacity="0.7"
                               FontSize="14"
                               TextWrapping="WrapWholeWords"/>

                    <!-- 版本号行：图标 + 版本 + 构建日期 -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <FontIcon Glyph="&#xE946;"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="VersionLabel"
                                   Text="v--.--.--  ·  ----/--/--"
                                   Opacity="0.55"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 应用信息区 -->
            <TextBlock Text="应用信息"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Margin="0,8,0,4"/>

            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20,14">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InfoVersionLabel"
                                   Text="v--.--.--"
                                   FontSize="14"/>
                        <TextBlock x:Name="InfoDateLabel"
                                   Text="构建日期：----/--/--"
                                   Opacity="0.55"
                                   FontSize="12"/>
                        <TextBlock x:Name="InfoAuthorLabel"
                                   Text="作者：HelloGaoo"
                                   Opacity="0.55"
                                   FontSize="12"/>
                    </StackPanel>

                    <Button Content="鸣谢"
                            Click="CreditsButton_Click"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            CornerRadius="6"
                            Padding="14,6"
                            FontSize="13"/>
                </Grid>
            </Border>

            <!-- 相关链接区 -->
            <TextBlock Text="相关链接"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Margin="0,16,0,4"/>

            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="16,10">
                <StackPanel Spacing="2">

                    <!-- GitHub 仓库 -->
                    <Button Click="GitHubVisit_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            HorizontalContentAlignment="Stretch"
                            Padding="0,5"
                            CornerRadius="6">
                        <Button.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Button.Background>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE70F;"
                                      FontSize="16"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="GitHub 仓库"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <TextBlock Text="github.com/HelloGaoo/ClassLively"
                                           Opacity="0.45"
                                           FontSize="11"/>
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE76C;"
                                      FontSize="12"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Bilibili -->
                    <Button Click="AuthorHomepage_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            HorizontalContentAlignment="Stretch"
                            Padding="0,5"
                            CornerRadius="6">
                        <Button.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Button.Background>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE71D;"
                                      FontSize="16"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="作者主页"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <TextBlock Text="space.bilibili.com/1498602348"
                                           Opacity="0.45"
                                           FontSize="11"/>
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE76C;"
                                      FontSize="12"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- 许可证 -->
                    <Button Click="LicenseButton_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            HorizontalContentAlignment="Stretch"
                            Padding="0,5"
                            CornerRadius="6">
                        <Button.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Button.Background>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE72C;"
                                      FontSize="16"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="许可证"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <TextBlock Text="GNU General Public License v3.0"
                                           Opacity="0.45"
                                           FontSize="11"/>
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE76C;"
                                      FontSize="12"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                </StackPanel>
            </Border>

            <!-- 更新日志区 -->
            <TextBlock Text="更新日志"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Margin="0,16,0,4"/>

            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20,12">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ChangelogVersionLabel"
                               Text="v--.--.--"
                               FontWeight="Normal"
                               FontSize="14"/>
                    <TextBox x:Name="ChangelogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="110"
                             PlaceholderText="114514"
                             FontFamily="Consolas"
                             FontSize="12"
                             Padding="14,10"
                             CornerRadius="6"/>
                </StackPanel>
            </Border>

            <!-- 版权信息 -->
            <TextBlock x:Name="CopyrightText"
                       Text="© 2026 HelloGaoo. All rights reserved."
                       HorizontalAlignment="Center"
                       Opacity="0.45"
                       FontSize="11"
                       Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
