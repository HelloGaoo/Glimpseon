<Page
    x:Class="ClassLively_UI.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,20">
        <StackPanel Spacing="24">

            <!-- 模式  下载源工具栏 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左：模式选择 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="选择模式:" VerticalAlignment="Center" FontSize="14" />
                    <RadioButton x:Name="SingleModeRadio"
                                 Content="单个下载"
                                 GroupName="DownloadMode"
                                 IsChecked="True"
                                 Checked="SingleModeRadio_Checked" />
                    <RadioButton x:Name="MultiModeRadio"
                                 Content="批量下载"
                                 GroupName="DownloadMode"
                                 Checked="MultiModeRadio_Checked" />
                    <Button x:Name="SelectAllBtn"
                            Content="全选"
                            Click="SelectAllBtn_Click"
                            Visibility="Collapsed" />
                </StackPanel>

                <!-- 右：下载源选择 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="下载源:" VerticalAlignment="Center" FontSize="14" />
                    <ComboBox x:Name="SourceCombo"
                              Width="180"
                              SelectionChanged="SourceCombo_SelectionChanged">
                        <ComboBoxItem Content="GitHub" Tag="github" IsSelected="True" />
                        <ComboBoxItem Content="Gitee" Tag="gitee" />
                        <ComboBoxItem Content="官网" Tag="official" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- 软件列表 -->
            <ItemsControl x:Name="SoftwareListUI">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Padding="16,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- 图标 -->
                                <Image Grid.Column="0"
                                       Width="48"
                                       Height="48"
                                       Source="{Binding Icon}"
                                       Stretch="Uniform" />

                                <!-- 名称 描述 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="15"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="400" />
                                        <FontIcon x:Name="LinkIcon"
                                                  Glyph="&#xE8A7;"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                  VerticalAlignment="Center"
                                                  ToolTipService.ToolTip="{Binding Link}"
                                                  Tapped="LinkIcon_Tapped" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}"
                                               Opacity="0.7"
                                               FontSize="13"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- 进度 / 下载按钮 / 复选框 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <ProgressRing x:Name="ItemProgress"
                                                  IsActive="False"
                                                  Width="36"
                                                  Height="36"
                                                  Visibility="Collapsed" />
                                    <Button x:Name="DownloadBtn"
                                            Content="下载"
                                            Click="DownloadBtn_Click"
                                            HorizontalContentAlignment="Center"
                                            MinWidth="72" />
                                    <CheckBox x:Name="ItemCheck"
                                              Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyTipText"
                       Text="暂无软件列表"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       Opacity="0.5"
                       Visibility="Collapsed" />

        </StackPanel>
    </ScrollViewer>

</Page>
