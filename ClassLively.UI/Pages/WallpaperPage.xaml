<Page
    x:Class="ClassLively_UI.Pages.WallpaperPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassLively_UI.Pages">

    <Page.Resources>
        <Style x:Key="SettingCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SettingIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="SliderValueBoxStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HistoryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="Width" Value="170" />
            <Setter Property="Height" Value="130" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="RootScrollViewer">
        <Grid>
            <!-- ═══ 内容区 ═══ -->
            <StackPanel Spacing="20" Margin="60,20,60,40">

                <!-- 标题 -->
                <TextBlock Text="壁纸" FontSize="32" FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <!-- 操作按钮行 -->
                <Border CornerRadius="10" Padding="12,8"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                        <Button x:Name="GetWallpaperBtn" Style="{StaticResource AccentButtonStyle}"
                                Click="GetWallpaper_Click" Grid.Column="0" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                <TextBlock Text="获取壁纸" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="SaveAsBtn" Margin="10,0,0,0"
                                Click="SaveAs_Click" Grid.Column="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                <TextBlock Text="另存为" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="SelectWallpaperBtn" Margin="10,0,0,0"
                                Click="SelectWallpaper_Click" Grid.Column="2" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8F4;" FontSize="14"/>
                                <TextBlock Text="手动选择" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="SetDesktopBtn"
                                Click="SetDesktop_Click" Grid.Column="4"
                                HorizontalAlignment="Right" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB9F;" FontSize="14"/>
                                <TextBlock Text="设为桌面" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- 信息卡：分辨率 | 大小 | 来源 | 路径 -->
                <Border CornerRadius="12" Padding="20"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        MinHeight="200">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">

                        <!-- 预览图 -->
                        <Grid Grid.Column="0" HorizontalAlignment="Left" MaxWidth="500">
                            <Border CornerRadius="10" Margin="3"
                                    Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}" Opacity="0.15" />
                            <Border x:Name="PreviewBorder" CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefault}">
                                <Image x:Name="PreviewImage" Stretch="UniformToFill" MaxHeight="280" />
                            </Border>
                        </Grid>

                        <!-- 信息标签 -->
                        <Border Grid.Column="1" VerticalAlignment="Center"
                                Margin="28,0,0,0" MinWidth="240"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1,0,0,0" Padding="24,16,0,16">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="分辨率" FontWeight="SemiBold" FontSize="13"
                                               Opacity="0.65" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="ResolutionLabel" Text="--" FontSize="16"
                                               FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="大小" FontWeight="SemiBold" FontSize="13"
                                               Opacity="0.65" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="FileSizeLabel" Text="--" FontSize="16"
                                               FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="来源" FontWeight="SemiBold" FontSize="13"
                                               Opacity="0.65" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="SourceLabel" Text="--" FontSize="16"
                                               FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="路径" FontWeight="SemiBold" FontSize="13"
                                               Opacity="0.65" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="PathLabel" Text="--" FontSize="13"
                                               FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{Binding Text, ElementName=PathLabel}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ 设置组 ═══ -->
                <StackPanel Spacing="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="设置" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    </StackPanel>

                    <!-- 保存数量上限 RangeSlider 10-100 -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <FontIcon Glyph="&#xE946;" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="保存数量上限" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="设置历史记录保存的最大条目数（10-100）" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="SaveLimitBox" Value="100" Minimum="10" Maximum="100" SmallChange="10"
                                       Width="70" Grid.Column="2" Grid.RowSpan="2"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       ValueChanged="SaveLimit_ValueChanged" />
                        </Grid>
                    </Border>

                    <!-- 自动获取间隔 ComboBox never/10m/30m/1h/3h/6h/12h/1d/3d/7d -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <FontIcon Glyph="&#xE81C;" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="自动获取间隔" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="设置自动更换壁纸的时间间隔" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="AutoIntervalCombo" Width="140" Grid.Column="2" Grid.RowSpan="2"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      SelectionChanged="AutoInterval_SelectionChanged">
                                <ComboBoxItem Content="关闭" Tag="never" IsSelected="True" />
                                <ComboBoxItem Content="10分钟" Tag="10m" />
                                <ComboBoxItem Content="30分钟" Tag="30m" />
                                <ComboBoxItem Content="1小时" Tag="1h" />
                                <ComboBoxItem Content="3小时" Tag="3h" />
                                <ComboBoxItem Content="6小时" Tag="6h" />
                                <ComboBoxItem Content="12小时" Tag="12h" />
                                <ComboBoxItem Content="1天" Tag="1d" />
                                <ComboBoxItem Content="3天" Tag="3d" />
                                <ComboBoxItem Content="7天" Tag="7d" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- 壁纸 API 来源 -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <FontIcon Glyph="&#xE774;" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="壁纸 API 来源" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="选择用于获取壁纸的 API 接口" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="ApiSourceCombo" Width="180" Grid.Column="2" Grid.RowSpan="2"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      SelectionChanged="ApiSource_SelectionChanged">
                                <ComboBoxItem Content="wp.upx8.com" IsSelected="True" />
                                <ComboBoxItem Content="api.ltyuanfang.cn" />
                                <ComboBoxItem Content="imlcd.cn_bg_high" />
                                <ComboBoxItem Content="imlcd.cn_bg_mc" />
                                <ComboBoxItem Content="imlcd.cn_bg_gq" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- 自动同步桌面 Switch -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <FontIcon Glyph="&#xEB9F;" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="自动同步桌面" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="获取新壁纸后自动设为桌面背景" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="AutoSyncToggle" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                         Toggled="AutoSync_Toggled" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ═══ 背景效果组 ═══ -->
                <StackPanel Spacing="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="背景效果" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    </StackPanel>

                    <!-- 模糊半径 Slider 0-30 -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <FontIcon Glyph="&#xE79E;" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="模糊程度" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="调整壁纸的模糊效果强度（0=无模糊，30=最大模糊）" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="12" Grid.Column="1" Grid.Row="2"
                                        VerticalAlignment="Center" Margin="0,8,0,0">
                                <Slider x:Name="BlurSlider" Minimum="0" Maximum="30"
                                        Width="260" VerticalAlignment="Center"
                                        ValueChanged="BlurSlider_ValueChanged" />
                                <Border Style="{StaticResource SliderValueBoxStyle}">
                                    <TextBlock x:Name="BlurValueLabel" Text="0" FontWeight="SemiBold"
                                               FontSize="13" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 亮度调节 Slider -100~0 -->
                    <Border Style="{StaticResource SettingCardStyle}">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <FontIcon Glyph="&#xE70F;" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SettingIconStyle}"/>
                            <TextBlock Text="亮度调节" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold"
                                       FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="调整壁纸的亮度（负值降低亮度，0=原始亮度）" Grid.Column="1" Grid.Row="1"
                                       Opacity="0.6" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="12" Grid.Column="1" Grid.Row="2"
                                        VerticalAlignment="Center" Margin="0,8,0,0">
                                <Slider x:Name="BrightnessSlider" Minimum="-100" Maximum="0"
                                        Width="260" VerticalAlignment="Center"
                                        ValueChanged="BrightnessSlider_ValueChanged" />
                                <Border Style="{StaticResource SliderValueBoxStyle}">
                                    <TextBlock x:Name="BrightnessValueLabel" Text="0" FontWeight="SemiBold"
                                               FontSize="13" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ═══ 历史记录组 ═══ -->
                <StackPanel Spacing="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <TextBlock Text="历史记录" FontSize="17" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" Grid.Column="0" />
                            <TextBlock x:Name="HistoryCountLabel" Text="(0)" Opacity="0.5" FontSize="13"
                                       Grid.Column="1" Margin="8,0,0,0"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button x:Name="ClearHistoryBtn" Content="清空全部" Grid.Column="2"
                                    Click="ClearHistory_Click" FontSize="12" CornerRadius="6" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    </StackPanel>

                    <!-- 空状态提示 -->
                    <StackPanel x:Name="EmptyHistoryPanel" Spacing="12"
                                HorizontalAlignment="Center" Padding="0,48,0,48">
                        <FontIcon Glyph="&#xE8A5;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorDisabledBrush}" Opacity="0.35" />
                        <TextBlock Text="暂无历史记录" FontSize="16"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" Opacity="0.55"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="点击「获取壁纸」开始收藏你喜欢的壁纸" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" Opacity="0.4"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- 缩略图网格 GridView -->
                    <GridView x:Name="HistoryGridView" Visibility="Collapsed">
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource HistoryCardStyle}"
                                        PointerPressed="HistoryItem_Click">
                                    <StackPanel Spacing="6">
                                        <Border CornerRadius="8" Height="94"
                                                Background="{ThemeResource CardBackgroundFillColorDefault}">
                                            <Image Source="{Binding ThumbnailUri}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding ResolutionText}"
                                                   FontSize="11" FontWeight="Medium"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Opacity="0.75" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <!-- 加载更多按钮 -->
                    <Button x:Name="LoadMoreBtn" Content="加载更多"
                            HorizontalAlignment="Center" Click="LoadMore_Click"
                            Visibility="Collapsed" Margin="0,8,0,0" CornerRadius="6" />
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
