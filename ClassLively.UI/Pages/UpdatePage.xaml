<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ClassLively_UI.Pages.UpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassLively_UI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,20">
        <StackPanel Spacing="24">

            <!-- 页面标题 -->
            <TextBlock Text="更新" Style="{StaticResource TitleTextBlockStyle}" FontSize="28" Margin="0,0,0,8" />

            <!-- 版本信息卡片-->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <!-- 图标  版本名 -->
                    <FontIcon Glyph="&#xE896;" FontSize="32" Width="48" Height="48"
                              Grid.Row="0" Grid.RowSpan="2"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Bottom" Spacing="2">
                        <TextBlock x:Name="AppTitleText" Text="ClassLively --" FontSize="18" FontWeight="Bold" />
                        <TextBlock x:Name="BuildDateText" Text="构建日期：--" Opacity="0.55" FontSize="12" />
                    </StackPanel>
                    <!-- 检查更新按钮 -->
                    <Button x:Name="CheckUpdateBtn" Content="检查更新"
                            Click="CheckUpdate_Click"
                            Grid.Column="2" Grid.RowSpan="2"
                            VerticalAlignment="Center" />

                    <!-- 状态指示器 -->
                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                 Fill="Green" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText" Text="已就绪"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 更新日志卡片-->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="更新日志" FontWeight="SemiBold" FontSize="15" />
                    </StackPanel>
                    <TextBox x:Name="ChangelogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="200"
                             PlaceholderText="点击检查更新以加载更新日志" />
                </StackPanel>
            </Border>

            <!--自动更新设置-->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <StackPanel Spacing="18">

                    <!-- 自动检查更新 -->
                    <Grid ColumnDefinitions="Auto,*">
                        <ToggleSwitch x:Name="AutoCheckSwitch" IsOn="False"
                                      Toggled="AutoCheck_Toggled"
                                      VerticalAlignment="Top" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="自动检查更新" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="启动时自动检查是否有新版本可用" Opacity="0.55" FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- 自动下载并安装更新 -->
                    <Grid ColumnDefinitions="Auto,*">
                        <ToggleSwitch x:Name="AutoUpdateSwitch" IsOn="False"
                                      Toggled="AutoUpdate_Toggled"
                                      VerticalAlignment="Top" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="自动更新" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="检测到新版本时自动下载并安装" Opacity="0.55" FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
