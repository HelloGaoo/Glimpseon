<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClassLively_UI.Pages.UpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="60,0,60,40">
        <StackPanel Spacing="16">

            <!-- 版本信息卡片 -->
            <Border x:Name="VersionCard"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="24">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- 48x48 图标 -->
                    <Border Width="48" Height="48" CornerRadius="24"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30C361" Offset="0"/>
                                <GradientStop Color="#1A9F3A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <FontIcon Glyph="&#xE790;"
                                  FontSize="22"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- 版本信息 -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                VerticalAlignment="Center" Spacing="4">
                        <TextBlock x:Name="AppTitleText"
                                   Text="ClassLively --.--.--"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBlock x:Name="BuildDateText"
                                   Text="构建日期：----/--/--"
                                   Opacity="0.6"
                                   FontSize="13"/>
                    </StackPanel>

                    <!-- 更新状态 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="8" Margin="16,8,0,0"
                                VerticalAlignment="Bottom">
                        <Ellipse x:Name="StatusDot"
                                 Width="16" Height="16"
                                 Fill="#107C10"/>
                        <TextBlock x:Name="StatusLabel"
                                   Text="已就绪"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <Button x:Name="CheckUpdateBtn"
                            Content="&#xE72C; 检查更新"
                            Click="CheckUpdate_Click"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Style="{StaticResource AccentButtonStyle}"
                            CornerRadius="6"
                            Padding="18,8"
                            FontSize="13"/>
                </Grid>
            </Border>

            <!-- 更新日志卡片 -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="更新日志"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <TextBox x:Name="ChangelogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="200"
                             PlaceholderText="更新日志将在自动检查更新时加载"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="14,10"
                             CornerRadius="6"/>
                </StackPanel>
            </Border>

            <!-- 自动检查更新 -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="24,20">
                <Grid ColumnDefinitions="Auto,*" MinHeight="56">
                    <ToggleSwitch x:Name="AutoCheckSwitch"
                                  Toggled="AutoCheck_Toggled"
                                  VerticalAlignment="Center"
                                  Margin="0,0,18,0"/>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="自动检查更新"
                                   FontWeight="SemiBold"
                                   FontSize="15"/>
                        <TextBlock Text="启用后，应用启动时会自动检查新版本"
                                   Opacity="0.55"
                                   FontSize="13"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 自动下载安装 -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="24,20">
                <Grid ColumnDefinitions="Auto,*" MinHeight="56">
                    <ToggleSwitch x:Name="AutoUpdateSwitch"
                                  Toggled="AutoUpdate_Toggled"
                                  VerticalAlignment="Center"
                                  Margin="0,0,18,0"/>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="自动更新"
                                   FontWeight="SemiBold"
                                   FontSize="15"/>
                        <TextBlock Text="发现新版本时自动下载并安装"
                                   Opacity="0.55"
                                   FontSize="13"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
