<Page
    x:Class="ClassLively_UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassLively_UI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingItemStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SettingIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>

        <x:String x:Key="ThemeColorDefault">#0078D4</x:String>
    </Page.Resources>

    <ScrollViewer Padding="36,24">
        <StackPanel Spacing="28">

            <!-- 页面标题 -->
            <TextBlock Text="设置" FontSize="32" FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <!-- ═══ 通用 ═══ -->
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="通用" Style="{StaticResource GroupTitleStyle}" />
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4" />
                </StackPanel>

                <!-- 开机自启动 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE768;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="开机自启动" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="设置应用在系统启动时自动运行" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="AutoStartSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="AutoStart_Toggled" />
                    </Grid>
                </Border>

                <!-- 空闲时自动打开 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE80F;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="空闲时自动打开" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="电脑空闲时自动从最小化打开界面" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="AutoOpenIdleSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="AutoOpenIdle_Toggled" />
                    </Grid>
                </Border>

                <!-- 空闲阈值 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE81C;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="空闲阈值（分钟）" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="电脑空闲多少分钟后触发自动打开（1-60 分钟）" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Slider x:Name="IdleMinutesSlider" Minimum="1" Maximum="60" Value="5"
                                Width="140" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                ValueChanged="IdleMinutes_ValueChanged" />
                    </Grid>
                </Border>

                <!-- 自动打开时最大化 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE740;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="自动打开时最大化" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="空闲自动打开界面时是否最大化窗口" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="AutoOpenMaximizeSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="AutoOpenMaximize_Toggled" />
                    </Grid>
                </Border>

                <!-- 允许运行多个实例 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE72C;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="允许运行多个实例" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="允许同时运行多个应用实例" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="AllowMultipleInstancesSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="AllowMultipleInstances_Toggled" />
                    </Grid>
                </Border>

                <!-- 调试模式 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE921;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="调试模式" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="启用调试模式以进行测试和调试" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="DebugModeSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="DebugMode_Toggled" />
                    </Grid>
                </Border>

                <!-- 关闭行为 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE713;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="关闭行为" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="点击关闭按钮时的行为" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ComboBox x:Name="CloseActionCombo" Width="130" Grid.Column="2" Grid.RowSpan="2"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  SelectionChanged="CloseAction_SelectionChanged">
                            <ComboBoxItem Content="最小化" Tag="minimize" IsSelected="True" />
                            <ComboBoxItem Content="关闭" Tag="close" />
                        </ComboBox>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ═══ 外观 ═══ -->
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="外观" Style="{StaticResource GroupTitleStyle}" />
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4" />
                </StackPanel>

                <!-- 主题模式 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE790;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="主题模式" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="更改应用程序的颜色外观" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ComboBox x:Name="ThemeModeCombo" Width="140" Grid.Column="2" Grid.RowSpan="2"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  SelectionChanged="ThemeMode_SelectionChanged">
                            <ComboBoxItem Content="浅色" Tag="light" IsSelected="True" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                            <ComboBoxItem Content="跟随系统" Tag="auto" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 主题色 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE790;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="主题色" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="更改应用程序的主题颜色" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Button x:Name="ThemeColorButton" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ThemeColor_Click" Padding="0" CornerRadius="6"
                                Background="#0078D4" Width="34" Height="34" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ═══ 日志 ═══ -->
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="日志" Style="{StaticResource GroupTitleStyle}" />
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4" />
                </StackPanel>

                <!-- 日志级别 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE946;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="日志级别" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="设置日志的输出级别" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ComboBox x:Name="LogLevelCombo" Width="100" Grid.Column="2" Grid.RowSpan="2"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  SelectionChanged="LogLevel_SelectionChanged">
                            <ComboBoxItem Content="DEBUG" Tag="debug" />
                            <ComboBoxItem Content="INFO" Tag="info" IsSelected="True" />
                            <ComboBoxItem Content="WARNING" Tag="warning" />
                            <ComboBoxItem Content="ERROR" Tag="error" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 禁用日志 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE89E;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="禁用日志" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="完全禁用日志输出" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <ToggleSwitch x:Name="DisableLogSwitch" IsOn="False" Grid.Column="2" Grid.RowSpan="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Toggled="DisableLog_Toggled" />
                    </Grid>
                </Border>

                <!-- 日志最大条数 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE946;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="日志最大条数" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="日志文件的最大条目数（50-500）" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Slider x:Name="LogMaxCountSlider" Minimum="50" Maximum="500" Value="100"
                                Width="140" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                ValueChanged="LogMaxCount_ValueChanged" />
                    </Grid>
                </Border>

                <!-- 日志最大天数 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE783;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="日志最大天数" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="日志文件的最大保存天数（30-365）" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Slider x:Name="LogMaxDaysSlider" Minimum="30" Maximum="365" Value="30"
                                Width="140" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                ValueChanged="LogMaxDays_ValueChanged" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ═══ 数据管理 ═══ -->
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="数据管理" Style="{StaticResource GroupTitleStyle}" />
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4" />
                </StackPanel>

                <!-- 清除缓存 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE74D;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="清除缓存" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="清除应用缓存数据" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Button Content="清除" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ClearCache_Click" />
                    </Grid>
                </Border>

                <!-- 重置所有设置 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE777;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="重置所有设置" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="将所有设置恢复到默认值" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Button Content="重置" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ResetSettings_Click" />
                    </Grid>
                </Border>

                <!-- 打开配置文件夹 -->
                <Border Style="{StaticResource SettingItemStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Glyph="&#xE8B7;" Grid.RowSpan="2" Style="{StaticResource SettingIconStyle}" />
                        <TextBlock Text="打开配置文件夹" Grid.Column="1" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="在资源管理器中打开配置目录" Grid.Column="1" Grid.Row="1"
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                        <Button Content="打开" Grid.Column="2" Grid.RowSpan="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="OpenConfigFolder_Click" />
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
