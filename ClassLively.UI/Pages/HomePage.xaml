<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ClassLively_UI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="HomeRoot">
        <!-- 壁纸背景 -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" />

        <!-- 暗化遮罩 -->
        <Border x:Name="DarkOverlay" Background="#80000000" />

        <!-- 组件画布 -->
        <Canvas x:Name="ComponentCanvas" />

        <!-- 辅助对齐线 -->
        <Canvas x:Name="GuideLineOverlay" IsHitTestVisible="False" />

        <!-- 编辑按钮 -->
        <Button x:Name="EditButton" Content="编辑布局"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,20" Width="80" Height="34"
                CornerRadius="17" Background="#80000000" Foreground="White"
                Click="EditButton_Click" />
    </Grid>
</Page>
