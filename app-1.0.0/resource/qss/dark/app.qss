/* 启动窗口 */

#contentWidget {
    background-color: rgba(32, 32, 32, 230);
    border-radius: 10px;
}

StrongBodyLabel {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: bold;
    font-family: "HarmonyOS Sans";
}

BodyLabel {
    color: #999999;
    font-size: 14px;
}

#versionLabel {
    color: #777777;
    font-size: 12px;
}

#statusLabel {
    color: #CCCCCC;
    font-size: 13px;
}

ProgressBar {
    background-color: #3A3A3A;
    border-radius: 2px;
    min-height: 4px;
    max-height: 4px;
}

ProgressBar::chunk {
    background-color: #0078D4;
    border-radius: 2px;
}

/* 向导窗口 */

WizardWindow {
    background-color: rgb(39, 39, 39);
    font-family: "HarmonyOS Sans", "Microsoft YaHei", "SimHei", sans-serif;
}

WizardWindow QWidget {
    background-color: rgb(39, 39, 39);
}

/* 标签 */

WizardWindow StrongBodyLabel {
    color: white;
    font-family: "HarmonyOS Sans", "Microsoft YaHei", "SimHei", sans-serif;
    font-size: 28px;
    margin-top: 8px;
    margin-bottom: 8px;
    font-weight: 900;
}

WizardWindow BodyLabel {
    color: rgba(255, 255, 255, 0.8);
    font-family: "HarmonyOS Sans", "Microsoft YaHei", "SimHei", sans-serif;
    font-size: 20px;
    margin-top: 6px;
    margin-bottom: 6px;
}

WizardWindow QLabel#titleLabel {
    color: white;
    font-family: "HarmonyOS Sans", "Microsoft YaHei", "SimHei", sans-serif;
    font-size: 16px;
    font-weight: bold;
}

WizardWindow QLabel#welcomeLabel {
    margin: 0;
    padding-left: 8px;
}

/* 控件 */

WizardWindow CheckBox {
    color: white;
    font-family: "HarmonyOS Sans", "Microsoft YaHei", "SimHei", sans-serif;
    font-size: 18px;
    margin-top: 4px;
    margin-bottom: 4px;
}

WizardWindow a {
    color: #4fc08d;
}

WizardWindow QPushButton#closeButton {
    background-color: transparent;
    border: none;
    color: white;
    font-size: 20px;
    border-radius: 15px;
}

WizardWindow QPushButton#closeButton:hover {
    background-color: #E81123;
    color: white;
    border: none;
}
